# Google Cloud credentials for Speech-to-Text
# Create a service account at console.cloud.google.com
# Download the JSON key and set the path here
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# Gemini API Key — used for event generation
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=HIDDENAPIKEY

# Server port
PORT=3000

# Max file size for uploads (bytes)
MAX_FILE_SIZE=10485760
